{
  "name": "@re-kit/strategy-rekit",
  "version": "0.1.0",
  "description": "re-kit strategy for projects without a native manifest (reads/writes a re-kit.json file).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onursagir/release-kit.git",
    "directory": "packages/strategy-rekit"
  },
